{
  "name": "@hieudoanm/graphql",
  "version": "0.0.1",
  "description": "hieudoanm - graphql",
  "main": "dist/main",
  "repository": "git@github.com:hieudoanm/hieudoanm.github.io.git",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "node": "20.11.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "dev": "rimraf dist && concurrently \"yarn dev:webpack\" \"yarn dev:nodemon\"",
    "dev:nodemon": "nodemon ./dist/main --watch dist",
    "dev:webpack": "webpack --progress --watch",
    "start": "node ./dist/main",
    "prebuild": "rimraf dist",
    "build": "webpack --mode=production",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@apollo/datasource-rest": "6.2.2",
    "@apollo/server": "4.10.0",
    "@graphql-tools/schema": "10.0.2",
    "cors": "2.8.5",
    "express": "4.18.2",
    "graphql": "16.8.1",
    "pino": "8.17.2",
    "pino-pretty": "10.3.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/jest": "29.5.11",
    "@types/node": "20.10.8",
    "@types/webpack-node-externals": "3.0.4",
    "@typescript-eslint/eslint-plugin": "6.18.1",
    "@typescript-eslint/parser": "6.18.1",
    "@webpack-cli/generators": "3.0.7",
    "concurrently": "8.2.2",
    "eslint": "8.56.0",
    "graphql-tag": "2.12.6",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "prettier": "3.1.1",
    "rimraf": "5.0.5",
    "ts-jest": "29.1.1",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "webpack": "5.89.0",
    "webpack-cli": "5.1.4",
    "webpack-node-externals": "3.0.0"
  },
  "resolutions": {
    "graphql": "16.8.1"
  }
}
