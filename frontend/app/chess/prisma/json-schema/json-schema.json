{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ChessPlayer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "username": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "location": {
          "type": "string",
          "default": ""
        },
        "country": {
          "$ref": "#/definitions/ChessCountry"
        },
        "avatar": {
          "type": "string",
          "default": ""
        },
        "twitchUrl": {
          "type": "string",
          "default": ""
        },
        "followers": {
          "type": "integer",
          "default": 0
        },
        "isStreamer": {
          "type": "boolean",
          "default": false
        },
        "verified": {
          "type": "boolean",
          "default": false
        },
        "lastOnline": {
          "type": "string",
          "format": "date-time"
        },
        "joined": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "default": "basic",
          "enum": [
            "basic",
            "premium",
            "staff",
            "mod"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "GM",
            "WGM",
            "IM",
            "WIM",
            "FM",
            "WFM",
            "CM",
            "WCM",
            "NM",
            "WNM",
            "AGM",
            "AIM",
            "AFM",
            "ACM"
          ]
        },
        "league": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Wood",
            "Stone",
            "Bronze",
            "Silver",
            "Crystal",
            "Elite",
            "Champion",
            "Legend"
          ]
        },
        "archives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stats": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ChessStats"
          }
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "ChessTitle": {
      "type": "object",
      "properties": {
        "abbreviation": {
          "type": "string",
          "enum": [
            "GM",
            "WGM",
            "IM",
            "WIM",
            "FM",
            "WFM",
            "CM",
            "WCM",
            "NM",
            "WNM",
            "AGM",
            "AIM",
            "AFM",
            "ACM"
          ]
        },
        "title": {
          "type": "string",
          "default": ""
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "ChessCountry": {
      "type": "object",
      "properties": {
        "cca2": {
          "type": "string",
          "default": ""
        },
        "cca3": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "flag": {
          "type": "string",
          "default": ""
        },
        "players": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ChessPlayer"
          }
        }
      }
    },
    "ChessStats": {
      "type": "object",
      "properties": {
        "player": {
          "$ref": "#/definitions/ChessPlayer"
        },
        "timeClass": {
          "type": "string",
          "default": "daily",
          "enum": [
            "daily",
            "classical",
            "rapid",
            "blitz",
            "bullet"
          ]
        },
        "best": {
          "type": "integer",
          "default": 0
        },
        "last": {
          "type": "integer",
          "default": 0
        },
        "deviation": {
          "type": "integer",
          "default": 0
        },
        "win": {
          "type": "integer",
          "default": 0
        },
        "draw": {
          "type": "integer",
          "default": 0
        },
        "loss": {
          "type": "integer",
          "default": 0
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "ChessGame": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "default": ""
        },
        "pgn": {
          "type": "string",
          "default": ""
        },
        "timeControl": {
          "type": "string",
          "default": ""
        },
        "timeClass": {
          "type": "string",
          "default": "daily",
          "enum": [
            "daily",
            "classical",
            "rapid",
            "blitz",
            "bullet"
          ]
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        },
        "rated": {
          "type": "boolean",
          "default": false
        },
        "tcn": {
          "type": "string",
          "default": ""
        },
        "initialSetup": {
          "type": "string",
          "default": ""
        },
        "rules": {
          "type": "string",
          "default": "chess",
          "enum": [
            "bughouse",
            "chess",
            "chess960",
            "crazyhouse",
            "kingofthehill",
            "oddschess",
            "threecheck"
          ]
        },
        "fen": {
          "type": "string",
          "default": ""
        },
        "whiteAccuracy": {
          "type": "number",
          "default": 0
        },
        "blackAccuracy": {
          "type": "number",
          "default": 0
        },
        "whiteUsername": {
          "type": "string",
          "default": ""
        },
        "blackUsername": {
          "type": "string",
          "default": ""
        },
        "whiteResult": {
          "type": "string",
          "default": "checkmated",
          "enum": [
            "win",
            "fiftymove",
            "agreed",
            "insufficient",
            "repetition",
            "stalemate",
            "timevsinsufficient",
            "checkmated",
            "resigned",
            "timeout",
            "abandoned",
            "bughousepartnerlose",
            "threecheck",
            "kingofthehill"
          ]
        },
        "blackResult": {
          "type": "string",
          "default": "checkmated",
          "enum": [
            "win",
            "fiftymove",
            "agreed",
            "insufficient",
            "repetition",
            "stalemate",
            "timevsinsufficient",
            "checkmated",
            "resigned",
            "timeout",
            "abandoned",
            "bughousepartnerlose",
            "threecheck",
            "kingofthehill"
          ]
        },
        "whiteRating": {
          "type": "integer",
          "default": 0
        },
        "blackRating": {
          "type": "integer",
          "default": 0
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "ChessOpening": {
      "type": "object",
      "properties": {
        "eco": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "fen": {
          "type": "string",
          "default": ""
        },
        "pgn": {
          "type": "string",
          "default": ""
        },
        "createdAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "chessPlayer": {
      "$ref": "#/definitions/ChessPlayer"
    },
    "chessTitle": {
      "$ref": "#/definitions/ChessTitle"
    },
    "chessCountry": {
      "$ref": "#/definitions/ChessCountry"
    },
    "chessStats": {
      "$ref": "#/definitions/ChessStats"
    },
    "chessGame": {
      "$ref": "#/definitions/ChessGame"
    },
    "chessOpening": {
      "$ref": "#/definitions/ChessOpening"
    }
  }
}