{
  "name": "@hieudoanm/broca",
  "version": "0.0.1",
  "description": "hieudoanm - broca",
  "main": "src/mobile",
  "repository": "git@github.com:hieudoanm/hieudoanm.github.io.git",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "npm": "10.4.0"
  },
  "scripts": {
    "check": "biome check --apply ./src",
    "format": "biome format --write ./src",
    "prettify": "prettier . --write --cache",
    "dev": "kill-port 3000 && next dev -p 3000",
    "dev:mobile": "kill-port 8081 && expo start",
    "dev:desktop": "kill-port 3000 && tauri dev",
    "prestart": "kill-port 3000",
    "start": "next start -p 3000",
    "prebuild": "rimraf .next out && (prisma generate || true)",
    "build": "next build",
    "lint": "next lint",
    "pretest": "rimraf coverage",
    "test": "jest",
    "prisma:migrate": "prisma format && prisma generate && prisma migrate dev --name init",
    "prisma:push": "prisma format && prisma generate && prisma db push"
  },
  "dependencies": {
    "axios": "1.6.7",
    "expo": "50.0.7",
    "expo-status-bar": "1.11.1",
    "next": "14.1.0",
    "next-pwa": "5.6.0",
    "pino": "8.19.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.4",
    "react-native-web": "0.19.10"
  },
  "devDependencies": {
    "@biomejs/biome": "1.5.3",
    "@prisma/client": "5.10.2",
    "@tauri-apps/cli": "1.5.10",
    "@testing-library/react": "14.2.1",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.20",
    "@types/react": "18.2.59",
    "@types/react-dom": "18.2.19",
    "autoprefixer": "10.4.17",
    "csvtojson": "2.0.10",
    "daisyui": "4.7.2",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.0",
    "jest": "29.7.0",
    "kill-port": "2.0.1",
    "postcss": "8.4.35",
    "prettier": "3.2.5",
    "prisma": "5.10.2",
    "prisma-dbml-generator": "0.12.0",
    "prisma-json-schema-generator": "5.1.1",
    "prisma-markdown": "1.0.9",
    "rimraf": "5.0.5",
    "sass": "1.71.1",
    "tailwindcss": "3.4.1",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  }
}
