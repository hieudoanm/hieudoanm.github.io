{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Language": {
      "type": "object",
      "properties": {
        "cca2": {
          "type": "string",
          "default": ""
        },
        "cca3": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "category": {
          "type": "integer",
          "default": 0
        },
        "duolingo": {
          "type": "boolean",
          "default": false
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Word": {
      "type": "object",
      "properties": {
        "word": {
          "type": "string"
        },
        "results": {
          "type": "array",
          "items": {
            "type": [
              "number",
              "string",
              "boolean",
              "object",
              "array",
              "null"
            ]
          }
        },
        "syllables": {
          "type": [
            "number",
            "string",
            "boolean",
            "object",
            "array",
            "null"
          ]
        },
        "pronunciation": {
          "type": [
            "number",
            "string",
            "boolean",
            "object",
            "array",
            "null"
          ]
        },
        "frequency": {
          "type": [
            "number",
            "null"
          ],
          "default": 0
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Quote": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "author": {
          "type": "string",
          "default": ""
        },
        "authorSlug": {
          "type": "string",
          "default": ""
        },
        "content": {
          "type": "string",
          "default": ""
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "TarotCard": {
      "type": "object",
      "properties": {
        "suit": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "CUPS",
            "PENTACLES",
            "SWORDS",
            "WANDS"
          ]
        },
        "type": {
          "type": "string",
          "default": "MAJOR",
          "enum": [
            "MAJOR",
            "MINOR"
          ]
        },
        "id": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "value": {
          "type": "string",
          "default": ""
        },
        "valueInt": {
          "type": "integer",
          "default": 0
        },
        "meaningUp": {
          "type": "string",
          "default": ""
        },
        "meaningReverse": {
          "type": "string",
          "default": ""
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "NewsSource": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "url": {
          "type": "string",
          "default": ""
        },
        "category": {
          "type": "string",
          "default": "GENERAL",
          "enum": [
            "BUSINESS",
            "ENTERTAINMENT",
            "GENERAL",
            "HEALTH",
            "SCIENCE",
            "SPORTS",
            "TECHNOLOGY"
          ]
        },
        "language": {
          "type": "string",
          "default": "EN",
          "enum": [
            "AR",
            "DE",
            "EN",
            "ES",
            "FR",
            "HE",
            "IT",
            "NL",
            "NO",
            "PT",
            "RU",
            "SV",
            "UD",
            "ZH"
          ]
        },
        "country": {
          "type": "string",
          "default": "US",
          "enum": [
            "AE",
            "AR",
            "AT",
            "AU",
            "BE",
            "BG",
            "BR",
            "CA",
            "CH",
            "CN",
            "CO",
            "CU",
            "CZ",
            "DE",
            "EG",
            "ES",
            "FR",
            "GB",
            "GR",
            "HK",
            "HU",
            "ID",
            "IE",
            "IL",
            "IN",
            "IS",
            "IT",
            "JP",
            "KR",
            "LT",
            "LV",
            "MA",
            "MX",
            "MY",
            "NG",
            "NL",
            "NO",
            "NZ",
            "PH",
            "PK",
            "PL",
            "PT",
            "RO",
            "RS",
            "RU",
            "SA",
            "SE",
            "SG",
            "SI",
            "SK",
            "TH",
            "TR",
            "TW",
            "UA",
            "US",
            "VE",
            "ZA",
            "ZH"
          ]
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "language": {
      "$ref": "#/definitions/Language"
    },
    "word": {
      "$ref": "#/definitions/Word"
    },
    "quote": {
      "$ref": "#/definitions/Quote"
    },
    "tarotCard": {
      "$ref": "#/definitions/TarotCard"
    },
    "newsSource": {
      "$ref": "#/definitions/NewsSource"
    }
  }
}