  "scripts": {
    "check": "biome check --apply ./src",
    "format": "biome format --write ./src",
    "prettify": "prettier . --write --cache",
    "predev": "rimraf .next out && yarn prisma:generate || true",
    "dev": "kill-port 3000 && next dev -p 3000",
    "prebuild": "rimraf .next out && (yarn prisma:generate || true)",
    "build": "next build",
    "prestart": "kill-port 3000",
    "start": "next start -p 3000",
    "lint": "next lint",
    "pretest": "rimraf coverage",
    "test": "jest",
    "prisma:generate": "prisma format && prisma generate"
  },
  "dependencies": {
    "next": "14.1.0",
    "next-pwa": "5.6.0",
