{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LicensePlate": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "EthnicGroup": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "group": {
          "type": "string",
          "default": ""
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "StockSymbol": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "market": {
          "type": "string",
          "default": "HOSE",
          "enum": ["HNX", "HOSE", "UPCOM"]
        },
        "vn30": {
          "type": "boolean",
          "default": false
        },
        "hnx30": {
          "type": "boolean",
          "default": false
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StockHistory"
          }
        }
      }
    },
    "StockHistory": {
      "type": "object",
      "properties": {
        "stock": {
          "anyOf": [
            {
              "$ref": "#/definitions/StockSymbol"
            },
            {
              "type": "null"
            }
          ]
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "open": {
          "type": ["number", "null"],
          "default": 0
        },
        "high": {
          "type": ["number", "null"],
          "default": 0
        },
        "low": {
          "type": ["number", "null"],
          "default": 0
        },
        "close": {
          "type": ["number", "null"],
          "default": 0
        },
        "volume": {
          "type": ["number", "null"],
          "default": 0
        },
        "ma50": {
          "type": ["number", "null"]
        },
        "ma200": {
          "type": ["number", "null"]
        },
        "goldenCross": {
          "type": "boolean",
          "default": false
        },
        "deathCross": {
          "type": "boolean",
          "default": false
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "licensePlate": {
      "$ref": "#/definitions/LicensePlate"
    },
    "ethnicGroup": {
      "$ref": "#/definitions/EthnicGroup"
    },
    "stockSymbol": {
      "$ref": "#/definitions/StockSymbol"
    },
    "stockHistory": {
      "$ref": "#/definitions/StockHistory"
    }
  }
}
