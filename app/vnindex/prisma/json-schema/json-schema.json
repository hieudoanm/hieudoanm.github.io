{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "LicensePlate": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "EthnicGroup": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "group": {
          "type": "string",
          "default": ""
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "StockSymbol": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "default": ""
        },
        "name": {
          "type": "string",
          "default": ""
        },
        "market": {
          "type": "string",
          "default": "HOSE",
          "enum": ["HNX", "HOSE", "UPCOM"]
        },
        "vn30": {
          "type": "boolean",
          "default": false
        },
        "hnx30": {
          "type": "boolean",
          "default": false
        },
        "sector": {
          "type": ["string", "null"],
          "enum": [
            "BANKING",
            "BASIC_RESOURCES",
            "CHEMICAL",
            "COMMUNICATIONS",
            "ELECTRICITY_WATER_PETROL",
            "FINANCIAL_SERVICES",
            "FOOD_BEVERAGE",
            "INDUSTRIAL_GOODS_SERVICES",
            "INFORMATION_TECHNOLOGY",
            "INSURANCE",
            "MEDICAL",
            "PETROLEUM",
            "REAL_ESTATE",
            "RETAIL",
            "TELECOMMUNICATION",
            "TRAVEL_ENTERTAINMENT"
          ]
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StockHistory"
          }
        }
      }
    },
    "StockHistory": {
      "type": "object",
      "properties": {
        "stock": {
          "anyOf": [
            {
              "$ref": "#/definitions/StockSymbol"
            },
            {
              "type": "null"
            }
          ]
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "open": {
          "type": ["number", "null"],
          "default": 0
        },
        "high": {
          "type": ["number", "null"],
          "default": 0
        },
        "low": {
          "type": ["number", "null"],
          "default": 0
        },
        "close": {
          "type": ["number", "null"],
          "default": 0
        },
        "volume": {
          "type": ["number", "null"],
          "default": 0
        },
        "change": {
          "type": ["number", "null"],
          "default": 0
        },
        "changePercentage": {
          "type": ["number", "null"],
          "default": 0
        },
        "bollingerUpperBand": {
          "type": ["number", "null"],
          "default": 0
        },
        "bollingerMiddleBand": {
          "type": ["number", "null"],
          "default": 0
        },
        "bollingerLowerBand": {
          "type": ["number", "null"],
          "default": 0
        },
        "bollingerOverbought": {
          "type": "boolean",
          "default": false
        },
        "bollingerOversold": {
          "type": "boolean",
          "default": false
        },
        "ma50": {
          "type": ["number", "null"],
          "default": 0
        },
        "ma200": {
          "type": ["number", "null"],
          "default": 0
        },
        "goldenCross": {
          "type": "boolean",
          "default": false
        },
        "deathCross": {
          "type": "boolean",
          "default": false
        },
        "mf": {
          "type": ["number", "null"],
          "default": 0
        },
        "mfPrice": {
          "type": ["number", "null"],
          "default": 0
        },
        "mfi": {
          "type": ["number", "null"],
          "default": 0
        },
        "mfiOversold": {
          "type": "boolean",
          "default": false
        },
        "mfiOverbought": {
          "type": "boolean",
          "default": false
        },
        "rsi": {
          "type": ["number", "null"],
          "default": 0
        },
        "rsiOversold": {
          "type": "boolean",
          "default": false
        },
        "rsiOverbought": {
          "type": "boolean",
          "default": false
        },
        "createdAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "licensePlate": {
      "$ref": "#/definitions/LicensePlate"
    },
    "ethnicGroup": {
      "$ref": "#/definitions/EthnicGroup"
    },
    "stockSymbol": {
      "$ref": "#/definitions/StockSymbol"
    },
    "stockHistory": {
      "$ref": "#/definitions/StockHistory"
    }
  }
}
