datasource db {
  provider = "postgresql"
  url      = env("POSTGRESQL_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

// generator docs {
//   provider = "node node_modules/prisma-docs-generator"
// }

generator jsonSchema {
  provider = "prisma-json-schema-generator"
}

generator nestjsDto {
  provider     = "prisma-generator-nestjs-dto"
  output       = "../src/generated"
  entitySuffix = "Dto"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "./README.md"
}

model Country {
  cca3         String     @id @default("") @db.VarChar(3)
  cca2         String?    @unique @default("") @db.VarChar(2)
  ccn3         String?    @unique @default("") @db.VarChar(3)
  startOfWeek  DayOfWeek? @default(MONDAY)
  region       Region?    @default(ANTARCTIC)
  subregion    String?    @default("") @db.VarChar(255)
  status       String?    @default("") @db.VarChar(255)
  flag         String?    @default("") @db.VarChar(255)
  area         Float?     @default(0)
  population   Int?       @default(0)
  independent  Boolean?   @default(false)
  unMember     Boolean?   @default(false)
  landlocked   Boolean?   @default(false)
  name         Json?      @default("{}")
  currencies   Json?      @default("{}")
  idd          Json?      @default("{}")
  languages    Json?      @default("{}")
  translations Json?      @default("{}")
  demonyms     Json?      @default("{}")
  maps         Json?      @default("{}")
  flags        Json?      @default("{}")
  car          Json?      @default("{}")
  capitalInfo  Json?      @default("{}")
  coatOfArms   Json?      @default("{}")
  postalCode   Json?      @default("{}")
  timezones    String[]   @default([])
  continents   String[]   @default([])
  latlng       Float[]    @default([])
  tld          String[]   @default([])
  capital      String[]   @default([])
  altSpellings String[]   @default([])

  organizations CountriesOnOrganizations[]

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Region {
  AFRICA
  AMERICAS
  ANTARCTIC
  ASIA
  EUROPE
  OCEANIA
}

model Currency {
  code   String @id @db.VarChar(3)
  name   String @db.VarChar(255)
  symbol String @db.VarChar(255)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model Language {
  code String @id @db.VarChar(3)
  name String @db.VarChar(255)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model Organization {
  code String  @id
  name String? @default("") @db.VarChar(255)

  countries CountriesOnOrganizations[]

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model CountriesOnOrganizations {
  organization     Organization @relation(fields: [organizationCode], references: [code])
  organizationCode String
  country          Country      @relation(fields: [countryCode], references: [cca3])
  countryCode      String
  accession        DateTime?
  withdrawal       DateTime?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  @@id([organizationCode, countryCode])
}

// Vietnam

model LicensePlate {
  code  String @id @db.VarChar(2)
  name  String @db.VarChar(255)
  group String @db.VarChar(255)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model EthnicGroup {
  id    Int    @id @default(autoincrement())
  name  String @default("") @db.VarChar(255)
  group String @default("") @db.VarChar(255)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

// Tarot

model TarotCard {
  type           TarotCardType @default(MAJOR)
  id             String        @id @default("")
  name           String?       @default("") @db.VarChar(255)
  value          String?       @default("") @db.VarChar(255)
  valueInt       Int?          @default(0)
  suit           String?       @default("") @db.VarChar(255)
  meaningUp      String?       @default("") @db.Text()
  meaningReverse String?       @default("") @db.Text()
  description    String?       @default("") @db.Text()

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

enum TarotCardType {
  MAJOR
  MINOR
}

enum TarotCardSuit {
  CUPS
  PENTACLES
  SWORDS
  WANDS
}

// News

model NewsSource {
  id          String             @id
  name        String             @default("") @db.VarChar(255)
  description String             @default("")
  url         String             @default("") @db.VarChar(255)
  category    NewsSourceCategory @default(GENERAL)
  language    String             @default("") @db.VarChar(2)
  country     String             @default("") @db.VarChar(2)
}

enum NewsSourceCategory {
  BUSINESS
  ENTERTAINMENT
  GENERAL
  HEALTH
  SCIENCE
  SPORTS
  TECHNOLOGY
}

model Word {
  word          String @id @db.VarChar(255)
  results       Json?  @default("{}")
  syllables     Json?  @default("{}")
  pronunciation Json?  @default("{}")
  frequency     Float? @default(0)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model TopLevelDomain {
  domain String  @id
  type   String? @default("")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

model ProgrammingLanguage {
  language     String                  @id
  color        String?                 @default("")
  type         ProgrammingLanguageType @default(PROGRAMMING)
  extensions   String[]                @default([])
  aliases      String[]                @default([])
  interpreters String[]                @default([])
  filenames    String[]                @default([])

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt
}

enum ProgrammingLanguageType {
  DATA
  MARKUP
  PROGRAMMING
  PROSE
}

// United States

model UnitedStatesCongress {
  congress        Int       @id
  houseControl    String?   @default("")
  senateControl   String?   @default("")
  congressControl String?   @default("")
  trifectaControl String?   @default("")
  startDate       DateTime?
  endDate         DateTime?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  UnitedStatesCongressMember              UnitedStatesCongressMember[]
  UnitedStatesCongressCommittee           UnitedStatesCongressCommittee[]
  UnitedStatesCongressMembersInCongresses UnitedStatesCongressMembersInCongresses[]
}

enum UnitedStatesCongressChamber {
  HOUSE
  SENATE
}

model UnitedStatesCongressMember {
  id          String    @id @default("")
  firstName   String?   @default("")
  middleName  String?   @default("")
  lastName    String?   @default("")
  suffix      String?   @default("")
  dateOfBirth DateTime?
  gender      String?   @default("")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  UnitedStatesCongress                    UnitedStatesCongress?                     @relation(fields: [unitedStatesCongressCongress], references: [congress])
  unitedStatesCongressCongress            Int?
  UnitedStatesCongressMembersInCongresses UnitedStatesCongressMembersInCongresses[]
  UnitedStatesCongressCommittee           UnitedStatesCongressCommittee[]
}

model UnitedStatesCongressMembersInCongresses {
  chamber        UnitedStatesCongressChamber @default(HOUSE)
  congress       UnitedStatesCongress        @relation(fields: [congressNumber], references: [congress])
  congressNumber Int
  member         UnitedStatesCongressMember  @relation(fields: [memberId], references: [id])
  memberId       String                      @default("")

  title          String?  @default("")
  shortTitle     String?  @default("")
  party          String?  @default("")
  leadershipRole String?  @default("")
  seniority      Int?     @default(0)
  state          String?  @default("")
  district       String?  @default("")
  atLarge        Boolean? @default(false)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  @@id([chamber, congressNumber, memberId])
}

model UnitedStatesCongressCommittee {
  chamber        UnitedStatesCongressChamber @default(HOUSE)
  congress       UnitedStatesCongress        @relation(fields: [congressNumber], references: [congress])
  congressNumber Int
  id             String                      @default("")
  name           String?                     @default("")
  chair          UnitedStatesCongressMember? @relation(fields: [chairId], references: [id])
  chairId        String?                     @default("")

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  @@id([congressNumber, chamber, id])
}

// Chess

model ChessPlayer {
  id                         Int         @id
  username                   String      @unique
  name                       String      @default("")
  followers                  Int         @default(0)
  avatar                     String      @default("")
  location                   String      @default("")
  country                    String      @default("")
  countryCode                String      @default("")
  twitchUrl                  String      @default("")
  isStreamer                 Boolean     @default(false)
  verified                   Boolean     @default(false)
  lastOnline                 DateTime    @default(now()) @db.Timestamptz
  joined                     DateTime    @default(now()) @db.Timestamptz
  status                     Status      @default(basic)
  title                      ChessTitle?
  league                     League?
  // Rapid
  statsDailyRatingBest       Int         @default(0)
  statsDailyRatingLast       Int         @default(0)
  statsDailyRatingDeviation  Int         @default(0)
  statsDailyRecordWin        Int         @default(0)
  statsDailyRecordDraw       Int         @default(0)
  statsDailyRecordLoss       Int         @default(0)
  // Rapid
  statsRapidRatingBest       Int         @default(0)
  statsRapidRatingLast       Int         @default(0)
  statsRapidRatingDeviation  Int         @default(0)
  statsRapidRecordWin        Int         @default(0)
  statsRapidRecordDraw       Int         @default(0)
  statsRapidRecordLoss       Int         @default(0)
  // Blitz
  statsBlitzRatingLast       Int         @default(0)
  statsBlitzRatingBest       Int         @default(0)
  statsBlitzRatingDeviation  Int         @default(0)
  statsBlitzRecordWin        Int         @default(0)
  statsBlitzRecordDraw       Int         @default(0)
  statsBlitzRecordLoss       Int         @default(0)
  // Bullet
  statsBulletRatingLast      Int         @default(0)
  statsBulletRatingBest      Int         @default(0)
  statsBulletRatingDeviation Int         @default(0)
  statsBulletRecordWin       Int         @default(0)
  statsBulletRecordDraw      Int         @default(0)
  statsBulletRecordLoss      Int         @default(0)
  // Archives
  archives                   String[]    @default([])
  createdAt                  DateTime?   @default(now()) @db.Timestamptz
  updatedAt                  DateTime?   @updatedAt @db.Timestamptz
}

enum Status {
  basic
  premium
}

enum League {
  Wood
  Stone
  Bronze
  Silver
  Crystal
  Elite
  Champion
  Legend
}

enum ChessTitle {
  GM
  WGM
  IM
  WIM
  FM
  WFM
  CM
  WCM
  NM
  WNM
  AGM
  AIM
  AFM
  ACM
}

model ChessGame {
  id            String         @id
  url           String         @default("")
  pgn           String         @default("")
  timeControl   String         @default("")
  timeClass     ChessTimeClass @default(daily)
  endTime       DateTime       @default(now()) @db.Timestamptz
  rated         Boolean        @default(false)
  tcn           String         @default("")
  initialSetup  String         @default("")
  rules         ChessVariant   @default(chess)
  whiteId       String         @default("")
  blackId       String         @default("")
  whiteUsername String         @default("")
  blackUsername String         @default("")
  whiteAccuracy Float          @default(0)
  blackAccuracy Float          @default(0)
  whiteResult   ChessResult    @default(checkmated)
  blackResult   ChessResult    @default(checkmated)
  whiteRating   Int            @default(0)
  blackRating   Int            @default(0)
  fen           String         @default("")
  createdAt     DateTime?      @default(now()) @db.Timestamptz
  updatedAt     DateTime?      @updatedAt @db.Timestamptz
}

enum ChessResult {
  win
  fiftymove
  agreed
  insufficient
  repetition
  stalemate
  timevsinsufficient
  checkmated
  resigned
  timeout
  abandoned
}

enum ChessTimeClass {
  daily
  classical
  rapid
  blitz
  bullet
}

enum ChessVariant {
  bughouse
  chess
  chess960
  crazyhouse
  kingofthehill
  oddschess
  threecheck
}

enum ChessPiece {
  king
  queen
  rook
  bishop
  knight
  pawn
}

enum Side {
  white
  black
}

model ChessOpening {
  eco       String    @default("")
  name      String    @default("")
  pgn       String    @default("")
  firstMove String    @default("")
  fen       String    @default("")
  centipawn Int       @default(0)
  createdAt DateTime? @default(now()) @db.Timestamptz
  updatedAt DateTime? @updatedAt @db.Timestamptz

  @@id([eco, name, pgn])
}
