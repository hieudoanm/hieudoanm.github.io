    "@types/web-bluetooth": "0.0.21",
    "eslint": "10.4.1",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
