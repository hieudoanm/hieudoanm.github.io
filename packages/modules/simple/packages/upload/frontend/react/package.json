    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jiti": "2.7.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
