{
  "name": "@lodashx/ts",
  "version": "0.0.1",
  "description": "Lodash Extensions",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "lodash "
  ],
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "license": "GPL-3.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "26.3.1"
  },
  "scripts": {
    "format": "prettier --cache --write .",
    "lint": "eslint . --fix",
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --detectOpenHandles"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "dependencies": {
    "yaml": "2.9.0"
  }
}
