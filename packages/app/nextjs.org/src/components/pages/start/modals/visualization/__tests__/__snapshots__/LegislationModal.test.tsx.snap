                class="h-2 rounded-full transition-all duration-500"
                style="width: 2%; background-color: rgb(139, 92, 246);"
              />
            </div>
            <span
              class="w-14 text-right font-mono"
            >
              2
               
              <span
                class="opacity-40"
              >
                (
                2.0
                %)
              </span>
            </span>
          </div>
        </div>
        <p
          class="mt-3 text-center text-xs opacity-30"
        >
          Data approximate — last updated 2024–2025
        </p>
      </div>
    </div>
    <form
      class="modal-backdrop"
      method="dialog"
    >
      <button>
        close
      </button>
    </form>
  </dialog>
</div>
`;
