                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="timeline-end self-center pl-2 md:pl-4"
            >
              <div
                class="invisible rounded-lg border border-transparent p-2 md:p-3"
              >
                <div
                  class="mb-0.5 h-4"
                />
                <div
                  class="h-12"
                />
              </div>
            </div>
            <hr
              class="bg-base-content/10"
            />
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
`;
