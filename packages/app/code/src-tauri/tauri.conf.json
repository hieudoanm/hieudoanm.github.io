{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "code",
  "version": "0.0.1",
  "identifier": "io.github.hieudoanm.code",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Code",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
