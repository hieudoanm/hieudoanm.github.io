pipeline {
    agent any

    tools {
        rust '1.85'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'cargo build --release'
            }
        }

        stage('Lint') {
            steps {
                sh 'cargo clippy -- -D warnings'
            }
        }

        stage('Test') {
            steps {
                sh 'cargo test --release'
            }
        }
    }
}
