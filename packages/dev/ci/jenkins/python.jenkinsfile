pipeline {
    agent any

    tools {
        python '3.14'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'python -m venv .venv'
                sh '. .venv/bin/activate && pip install -r requirements.txt'
            }
        }

        stage('Lint') {
            steps {
                sh '. .venv/bin/activate && ruff check .'
            }
        }

        stage('Test') {
            steps {
                sh '. .venv/bin/activate && pytest -v --cov'
            }
        }
    }
}
