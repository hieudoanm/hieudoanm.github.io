BINARY_NAME = hieudoanm
BUILD_DIR = .build
INSTALL_DIR = $(HOME)/bin
SWIFT_BUILD_FLAGS = -c release

FULL_VERSION ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo "dev")
GIT_COMMIT ?= $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_DATE ?= $(shell date -u +%Y-%m-%dT%H:%M:%SZ)

.PHONY: all build clean install lint format run test help

all: build

build:
	@mkdir -p Sources/hieudoanm/Generated
	@printf '// Auto-generated by Makefile. Do not edit.\n' > Sources/hieudoanm/Generated/BuildInfo.swift
	@printf 'enum BuildInfo {\n' >> Sources/hieudoanm/Generated/BuildInfo.swift
	@printf '    static let fullVersion = "%s"\n' "$(FULL_VERSION)" >> Sources/hieudoanm/Generated/BuildInfo.swift
	@printf '    static let gitCommit = "%s"\n' "$(GIT_COMMIT)" >> Sources/hieudoanm/Generated/BuildInfo.swift
	@printf '    static let buildDate = "%s"\n' "$(BUILD_DATE)" >> Sources/hieudoanm/Generated/BuildInfo.swift
	@printf '}\n' >> Sources/hieudoanm/Generated/BuildInfo.swift
	swift build $(SWIFT_BUILD_FLAGS)
	install -d "$(INSTALL_DIR)"
	install "$(BUILD_DIR)/release/$(BINARY_NAME)" "$(INSTALL_DIR)/$(BINARY_NAME)"

install: build

test:
	swift test

clean:
	rm -rf "$(BUILD_DIR)"
	rm -rf ".swiftpm"

lint:
	swift format lint --recursive Sources/

format:
	swift format --recursive Sources/

run: build
	"$(BUILD_DIR)/release/$(BINARY_NAME)"

help:
	@echo "Usage:"
	@echo "  make build    - Build the binary and copy to ~/bin"
	@echo "  make install  - Alias for build"
	@echo "  make test     - Run tests"
	@echo "  make clean    - Remove build artifacts"
	@echo "  make lint     - Lint Swift source code"
	@echo "  make format   - Format Swift source code"
