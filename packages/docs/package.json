  "keywords": [
    "next.js"
  ],
  "homepage": "https://hieudoanm.github.io/hieudoanm",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/hieudoanm.git"
  },
  "bugs": {
    "url": "https://github.com/hieudoanm/hieudoanm/issues"
  },
