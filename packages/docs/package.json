  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "25.8.1"
  },
  "scripts": {
    "prebuild": "rimraf ../../docs",
    "build": "rimraf ../../docs && docsify init ../../docs",
    "test": "true",
    "lint": "true",
    "format": "prettier --cache --write .",
    "predev": "rimraf ./docs && docsify init ./docs",
    "dev": "docsify serve ./docs --theme pure"
  },
  "devDependencies": {
    "docsify-cli": "4.4.4",
    "prettier": "3.8.1",
    "rimraf": "6.1.3"
  }
