  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/svg.git"
  },
  "bugs": {
    "url": "https://github.com/hieudoanm/svg/issues"
  },
  "homepage": "https://hieudoanm.github.io/svg",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "26.4.0",
    "vscode": "1.999.0"
  },
  "scripts": {
    "format": "prettier --cache --write .",
