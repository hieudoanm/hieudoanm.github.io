{
  "name": "Claude Limit",
  "version": "1.0.0",
  "description": "Automatically limit Claude chat messages to prevent overusing the free tier",
  "author": "Hieu Doan",
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-limit@hieudoanm.github.io"
    }
  },
  "homepage_url": "https://hieudoanm.github.io",
  "offline_enabled": true,
  "content_scripts": [
    {
      "matches": [
        "https://claude.com/*"
      ],
      "js": [
        "background.js",
        "content.js"
      ]
    }
  ],
  "manifest_version": 2,
  "icons": {
    "128": "icons/128x128.png"
  }
}
