{
  "name": "Shopify Detect",
  "version": "0.0.1",
  "description": "Detects Shopify and Shopify Plus stores",
  "browser_specific_settings": {
    "gecko": {
      "id": "shopify-detect-ext@hieudoanm.github.io"
    }
  },
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "public/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "manifest_version": 3
}
