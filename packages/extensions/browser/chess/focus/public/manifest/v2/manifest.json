{
  "name": "Chess Focus",
  "version": "0.0.1",
  "description": "Hide Username and Ratings on chess.com",
  "author": "Hieu Doan",
  "icons": {
    "128": "icons/128x128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nothing-chess@hieudoanm.github.io"
    }
  },
  "homepage_url": "https://hieudoanm.github.io",
  "offline_enabled": true,
  "permissions": [
    "*://chess.com/*"
  ],
  "browser_action": {
    "default_icon": {
      "128": "icons/128x128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chess.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "manifest_version": 2
}
