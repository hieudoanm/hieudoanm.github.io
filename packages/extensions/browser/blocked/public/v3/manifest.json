{
  "name": "blocked",
  "version": "0.0.1",
  "description": "Blocks a list of websites you define.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hieumdoan@gmail.com",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "manifest_version": 3
}