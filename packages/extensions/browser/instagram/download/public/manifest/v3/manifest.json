{
  "name": "Instagram Image Downloader",
  "version": "0.0.1",
  "description": "Click any Instagram image to download it instantly.",
  "icons": {
    "128": "icons/128x128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "instagram-download-ext@hieudoanm.github.io"
    }
  },
  "permissions": [
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://scontent*.cdninstagram.com/*",
    "https://scontent*.fbcdn.net/*",
    "https://instagram*.fna.fbcdn.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Downloader",
    "default_icon": {
      "128": "icons/128x128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "manifest_version": 3
}
