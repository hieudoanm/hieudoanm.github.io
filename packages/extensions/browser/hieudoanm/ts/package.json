{
  "name": "@hieudoanm.github.io/extension",
  "version": "0.0.1",
  "private": true,
  "description": "Block Ads, Banners, and distracting Sites browser extension",
  "main": "dist/background.js",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/hieudoanm.git"
  },
  "bugs": {
    "url": "https://github.com/hieudoanm/hieudoanm/issues"
  },
  "homepage": "https://hieudoanm.github.io/hieudoanm",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "license": "GPL-3.0",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "26.4.0"
  },
  "scripts": {
    "clean": "rimraf dist && rimraf download",
    "prebuild": "pnpm run clean && pnpm run lint && pnpm run format",
    "build": "webpack --config webpack.config.ts",
    "postbuild": "make build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --cache --write ."
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.1",
    "@eslint/markdown": "8.0.3",
    "@types/chrome": "0.2.2",
    "@types/firefox-webext-browser": "143.0.0",
    "@types/node": "26.1.1",
    "@webpack-cli/generators": "3.0.7",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "sharp": "0.35.3",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "web-ext": "10.4.0",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1"
  },
  "keywords": [
    "block",
    "ads",
    "sites"
  ]
