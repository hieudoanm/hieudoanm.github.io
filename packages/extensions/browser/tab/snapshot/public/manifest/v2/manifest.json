{
  "name": "SnapShot",
  "version": "1.0.0",
  "description": "Capture the current browser tab as a PNG with one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "snapshot-ext@hieudoanm.github.io"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "SnapShot – Capture Tab",
    "default_icon": {
      "128": "icons/128x128.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "manifest_version": 2,
  "icons": {
    "128": "icons/128x128.png"
  }
}
