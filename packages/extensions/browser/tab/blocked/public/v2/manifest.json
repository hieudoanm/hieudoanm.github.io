{
  "name": "blocked",
  "version": "0.0.1",
  "description": "Blocks a list of websites you define.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hieumdoan@gmail.com",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "manifest_version": 2
}