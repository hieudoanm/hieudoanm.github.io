datasource db {
  provider = "postgresql"
  url      = env("CHESS_POSTGRESQL_URL")
  schemas  = ["chess"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../../src/generated/prisma/chess/client"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

generator jsonSchema {
  provider = "prisma-json-schema-generator"
}

generator nestjsDto {
  provider     = "prisma-generator-nestjs-dto"
  output       = "../../src/generated/prisma/chess/dto"
  reExport = true
  entitySuffix = "Dto"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "./README.md"
}

model ChessPlayer {
  id          Int          @id
  username    String       @unique
  name        String       @default("")
  followers   Int          @default(0)
  avatar      String       @default("")
  location    String       @default("")
  country     String       @default("")
  countryCode String       @default("")
  twitchUrl   String       @default("")
  isStreamer  Boolean      @default(false)
  verified    Boolean      @default(false)
  lastOnline  DateTime     @default(now()) @db.Timestamptz
  joined      DateTime     @default(now()) @db.Timestamptz
  status      ChessStatus  @default(basic)
  title       ChessTitle?
  league      ChessLeague?
  archives    String[]     @default([])

  stats ChessStats[]

  createdAt DateTime? @default(now()) @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz

  @@schema("chess")
}

enum ChessStatus {
  basic
  premium
  staff

  @@schema("chess")
}

enum ChessLeague {
  Wood
  Stone
  Bronze
  Silver
  Crystal
  Elite
  Champion
  Legend

  @@schema("chess")
}

enum ChessTitle {
  GM
  WGM
  IM
  WIM
  FM
  WFM
  CM
  WCM
  NM
  WNM
  AGM
  AIM
  AFM
  ACM

  @@schema("chess")
}

model ChessStats {
  player    ChessPlayer    @relation(fields: [playerId], references: [id])
  playerId  Int
  timeClass ChessTimeClass @default(daily)
  best      Int            @default(0)
  last      Int            @default(0)
  deviation Int            @default(0)
  win       Int            @default(0)
  draw      Int            @default(0)
  loss      Int            @default(0)

  createdAt DateTime? @default(now()) @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz

  @@id([playerId, timeClass])
  @@schema("chess")
}

enum ChessTimeClass {
  daily
  classical
  rapid
  blitz
  bullet

  @@schema("chess")
}

model ChessGame {
  id            String         @id
  url           String         @default("")
  pgn           String         @default("")
  timeControl   String         @default("")
  timeClass     ChessTimeClass @default(daily)
  endTime       DateTime       @default(now()) @db.Timestamptz
  rated         Boolean        @default(false)
  tcn           String         @default("")
  initialSetup  String         @default("")
  rules         ChessVariant   @default(chess)
  fen           String         @default("")
  whiteAccuracy Float          @default(0)
  blackAccuracy Float          @default(0)
  whiteUsername String         @default("")
  blackUsername String         @default("")
  whiteResult   ChessResult    @default(checkmated)
  blackResult   ChessResult    @default(checkmated)
  whiteRating   Int            @default(0)
  blackRating   Int            @default(0)
  createdAt     DateTime?      @default(now()) @db.Timestamptz
  updatedAt     DateTime?      @default(now()) @updatedAt @db.Timestamptz

  @@schema("chess")
}

enum ChessResult {
  win
  fiftymove
  agreed
  insufficient
  repetition
  stalemate
  timevsinsufficient
  checkmated
  resigned
  timeout
  abandoned
  bughousepartnerlose
  threecheck
  kingofthehill

  @@schema("chess")
}

enum ChessVariant {
  bughouse
  chess
  chess960
  crazyhouse
  kingofthehill
  oddschess
  threecheck

  @@schema("chess")
}

enum ChessPiece {
  king
  queen
  rook
  bishop
  knight
  pawn

  @@schema("chess")
}

enum ChessSide {
  white
  black

  @@schema("chess")
}

model ChessOpening {
  eco  String @default("")
  name String @default("")
  pgn  String @default("")

  createdAt DateTime? @default(now()) @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @db.Timestamptz

  @@id([eco, name, pgn])
  @@schema("chess")
}
