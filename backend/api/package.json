{
  "name": "@hieudoanm/api",
  "version": "0.0.1",
  "description": "hieudoanm - API",
  "main": "dist/main",
  "repository": "git@github.com:hieudoanm/hieudoanm.github.io.git",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist && (yarn docs || true) & yarn prisma generate",
    "build": "nest build",
    "format": "biome format --write ./src ./test",
    "start": "nest start",
    "dev": "yarn start:dev",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docs": "yarn docs:swagger && yarn docs:postman",
    "docs:postman": "openapi2postmanv2 -s docs/swagger/swagger.yaml -o docs/postman/collection.json",
    "docs:swagger": "redocly build-docs ./docs/swagger/swagger.json --output ./public/index.html --title 'hieudoanm - api'",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:init": "make prisma-init"
  },
  "dependencies": {
    "@nestjs/axios": "3.0.1",
    "@nestjs/cache-manager": "2.2.0",
    "@nestjs/common": "10.3.1",
    "@nestjs/config": "3.1.1",
    "@nestjs/core": "10.3.1",
    "@nestjs/platform-express": "10.3.1",
    "@nestjs/serve-static": "4.0.0",
    "@nestjs/swagger": "7.2.0",
    "@nestjs/throttler": "5.1.1",
    "axios": "1.6.7",
    "cache-manager": "5.4.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "compression": "1.7.4",
    "cookie-parser": "1.4.6",
    "helmet": "7.1.0",
    "ioredis": "5.3.2",
    "reflect-metadata": "0.2.1",
    "rxjs": "7.8.1",
    "yaml": "2.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.5.3",
    "@nestjs/cli": "10.3.0",
    "@nestjs/schematics": "10.1.0",
    "@nestjs/testing": "10.3.1",
    "@prisma/client": "5.8.1",
    "@redocly/cli": "1.8.0",
    "@types/cookie-parser": "1.4.6",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/node": "20.11.10",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "6.19.1",
    "@typescript-eslint/parser": "6.19.1",
    "@vegardit/prisma-generator-nestjs-dto": "1.5.1",
    "eslint": "8.56.0",
    "eslint-plugin-github": "4.10.1",
    "eslint-plugin-sonarjs": "0.23.0",
    "jest": "29.7.0",
    "openapi-to-postmanv2": "4.19.0",
    "prisma": "5.8.1",
    "prisma-dbml-generator": "0.10.0",
    "prisma-docs-generator": "0.8.0",
    "prisma-json-schema-generator": "5.1.1",
    "prisma-markdown": "1.0.8",
    "source-map-support": "0.5.21",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.3.3"
  }
}
